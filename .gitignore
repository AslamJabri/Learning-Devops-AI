# ==========================================
# Python & DSA (dsa-python/)
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
.venv/
venv/
ENV/
env/

# Pipenv (if you use it outside the dsa-python/import folder)
.env

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# ==========================================
# Terraform (terraform/)
# ==========================================
# Local .terraform directories (contains providers and modules)
**/.terraform/

# Terraform State Files (CRITICAL: Never commit these as they may contain secrets)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include tool-specific variables
*.tfvars
*.tfvars.json

# Ignore CLI configuration
.terraformrc
terraform.rc

# ==========================================
# Security & Sensitive Data
# ==========================================
# Specific files found in your tree that should likely be ignored
terraform/security/password.txt
**/demo.txt

# General Secrets
*.log
*.key
*.pem
.env
.secrets

# ==========================================
# OS & IDE Specific
# ==========================================
.DS_Store
.idea/
.vscode/
*.swp

# Hugging Face & AI Models
models/
.cache/
hub/
*.bin
*.onnx
*.gguf
*.safetensors

# Vector Databases (ChromaDB, FAISS, etc.)
# LangChain often creates these locally
chroma/
faiss_index/
vector_store/
# Avoid committing massive model weights
checkpoints/
data/
*.ckpt
.huggingface/

# Environment variables for API keys (OpenAI, Anthropic, etc.)
.env
.env.*
!.env.example

helm/server/
